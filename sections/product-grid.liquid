  margin: 0 0 8px 0;
  color: #1a1a1a;
}

.current-price {
  font-size: 1.125rem;
  font-weight: 600;
  color: #1a1a1a;
}

.current-price.sale {
  color: #e63946;
}

.compare-price {
  font-size: 0.875rem;
  color: #999;
  text-decoration: line-through;
  margin-left: 8px;
}

/* Popup Styles */
.popup-overlay {
