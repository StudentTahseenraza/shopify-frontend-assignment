<script>
(function() {
  'use strict';
  
  let currentProductData = null;
  let currentVariant = null;
  let selectedSize = null;
  let selectedColor = null;
  let isAddingToCart = false;
  let currentBundleHandle = null;
  let bundleProductCache = new Map();
  let addedBundles = new Set();
  
  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }
  
  function showMessage(message, isError = false) {
    const messageDiv = document.getElementById('cart-message');
    if (messageDiv) {
      messageDiv.textContent = message;
      messageDiv.className = `cart-message ${isError ? 'error' : 'success'}`;
      setTimeout(() => {
        messageDiv.classList.remove('success', 'error');
        messageDiv.textContent = '';
      }, 3000);
    }
  }
  
  async function fetchProduct(handle) {
    try {
      const response = await fetch(`/products/${handle}.js`);
      if (!response.ok) throw new Error('Product not found');
      return await response.json();
    } catch (error) {
      console.error('Error fetching product:', error);
      return null;
    }
  }
  
  async function fetchBundleProduct(bundleHandle) {
    if (!bundleHandle || bundleHandle === '') {
      return null;
    }
    
    if (bundleProductCache.has(bundleHandle)) {
      return bundleProductCache.get(bundleHandle);
    }
    
    const product = await fetchProduct(bundleHandle);
    if (product) {
      bundleProductCache.set(bundleHandle, product);
      console.log(`✅ Bundle product loaded: ${product.title}`);
    } else {
      console.log(`❌ Bundle product "${bundleHandle}" not found`);
    }
    return product;
  }
  
  async function addToCart(variantId, quantity, productName = 'Product') {
    try {
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId), quantity: parseInt(quantity) })
      });
      
      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.description || 'Failed to add to cart');
      }
      
      console.log(`✅ Added to cart: ${productName}`);
      return await response.json();
    } catch (error) {
      console.error(`Failed to add ${productName}:`, error);
      throw error;
    }
  }
  
  async function addBundleToCart(bundleHandle, mainProductId, mainProductTitle) {
    if (!bundleHandle || bundleHandle === '') {
      console.log(`ℹ️ No bundle product configured for: ${mainProductTitle}`);
      return false;
    }
    
    const bundleKey = `${mainProductId}_${bundleHandle}`;
    
    if (addedBundles.has(bundleKey)) {
      console.log(`⚠️ Bundle already added for ${mainProductTitle}, skipping duplicate`);
      return false;
    }
    
    const bundleProduct = await fetchBundleProduct(bundleHandle);
    if (!bundleProduct || !bundleProduct.variants || bundleProduct.variants.length === 0) {
      console.log(`❌ Bundle product "${bundleHandle}" not found in your store`);
      return false;
    }
    
    try {
      await addToCart(bundleProduct.variants[0].id, 1, bundleProduct.title);
      addedBundles.add(bundleKey);
      showMessage(`🎁 Special offer: ${bundleProduct.title} added to your cart!`);
      console.log(`✅ Bundle added: ${bundleProduct.title} for ${mainProductTitle}`);
      return true;
    } catch (error) {
      console.error('Failed to add bundle:', error);
      return false;
    }
  }
  
  function updateVariantOptions(product) {
    const sizes = new Set();
    const colors = new Set();
    
    product.variants.forEach(variant => {
      variant.options.forEach(option => {
        if (['XS', 'S', 'M', 'L', 'XL', 'XXL'].includes(option)) {
          sizes.add(option);
        } else if (['Black', 'White', 'Red', 'Blue', 'Green', 'Yellow', 'Pink', 'Brown'].includes(option)) {
          colors.add(option);
        }
      });
    });
    
    const sizeContainer = document.getElementById('size-options');
    if (sizeContainer) {
      sizeContainer.innerHTML = '';
      if (sizes.size === 0) {
        ['XS', 'S', 'M', 'L'].forEach(size => sizes.add(size));
      }
      sizes.forEach(size => {
        const option = document.createElement('button');
        option.className = 'variant-option';
        if (selectedSize === size) option.classList.add('selected');
        option.textContent = size;
        option.onclick = () => {
          document.querySelectorAll('#size-options .variant-option').forEach(opt => opt.classList.remove('selected'));
          option.classList.add('selected');
          selectedSize = size;
          console.log('📏 Size selected:', size);
          updateSelectedVariant(product);
        };
        sizeContainer.appendChild(option);
      });
    }
    
    const colorContainer = document.getElementById('color-options');
    if (colorContainer) {
      colorContainer.innerHTML = '';
      if (colors.size === 0) {
        ['Black', 'White'].forEach(color => colors.add(color));
      }
      colors.forEach(color => {
        const option = document.createElement('button');
        option.className = 'variant-option';
        if (selectedColor === color) option.classList.add('selected');
        option.textContent = color;
        option.onclick = () => {
          document.querySelectorAll('#color-options .variant-option').forEach(opt => opt.classList.remove('selected'));
          option.classList.add('selected');
          selectedColor = color;
          console.log('🎨 Color selected:', color);
          updateSelectedVariant(product);
        };
        colorContainer.appendChild(option);
      });
    }
  }
  
  function updateSelectedVariant(product) {
    if (selectedSize && selectedColor) {
      currentVariant = product.variants.find(variant => {
        return variant.options.includes(selectedSize) && variant.options.includes(selectedColor);
      });
      if (currentVariant) {
        const priceElement = document.getElementById('popup-product-price');
        if (priceElement) {
          priceElement.textContent = formatMoney(currentVariant.price);
        }
        console.log('🔄 Variant updated:', {
          size: selectedSize,
          color: selectedColor,
          variantId: currentVariant.id
        });
      }
    }
  }
  
  function resetVariants() {
    selectedColor = null;
    selectedSize = null;
    currentVariant = null;
    document.querySelectorAll('.variant-option').forEach(opt => opt.classList.remove('selected'));
  }
  
  async function handleAddToCart() {
    if (isAddingToCart) {
      console.log('⏳ Already processing...');
      return;
    }
    
    if (!currentProductData) {
      showMessage('Loading product details...', true);
      return;
    }
    
    const quantity = parseInt(document.getElementById('quantity-input')?.value) || 1;
    const variantToAdd = currentVariant || currentProductData.variants[0];
    
    if (!variantToAdd) {
      showMessage('Please select size and color', true);
      return;
    }
    
    console.log('📦 Processing main product:', {
      productName: currentProductData.title,
      productId: currentProductData.id,
      size: selectedSize,
      color: selectedColor,
      bundleHandle: currentBundleHandle
    });
    
    isAddingToCart = true;
    const btn = document.getElementById('add-to-cart-btn');
    const originalText = btn?.innerHTML;
    
    if (btn) {
      btn.innerHTML = 'Adding...';
      btn.disabled = true;
    }
    
    try {
      await addToCart(variantToAdd.id, quantity, currentProductData.title);
      
      if (selectedColor === 'Black' && selectedSize === 'M') {
        console.log('🎯 Black + M detected!');
        
        if (currentBundleHandle && currentBundleHandle !== '') {
          console.log(`📦 Bundle product for ${currentProductData.title}: ${currentBundleHandle}`);
          await addBundleToCart(currentBundleHandle, currentProductData.id, currentProductData.title);
        } else {
          console.log(`ℹ️ No bundle product configured for ${currentProductData.title}`);
        }
      } else {
        console.log('ℹ️ Bundle condition not met (requires Black + M)');
      }
      
      await updateCartCount();
      showMessage(`✓ ${currentProductData.title} added to cart!`);
      setTimeout(() => closePopup(), 2000);
    } catch (error) {
      console.error('Error:', error);
      showMessage('Failed to add to cart', true);
    } finally {
      if (btn) {
        btn.innerHTML = originalText || 'Add to Cart';
        btn.disabled = false;
      }
      isAddingToCart = false;
    }
  }
  
  async function updateCartCount() {
    try {
      const response = await fetch('/cart.js');
      const cart = await response.json();
      const selectors = ['.cart-count', '.cart-item-count', '.site-header__cart-count'];
      selectors.forEach(sel => {
        document.querySelectorAll(sel).forEach(el => {
          if (el) el.textContent = cart.item_count;
        });
      });
    } catch (error) {
      console.error('Error updating cart:', error);
    }
  }
  
  window.openProductPopup = async function(handle, title, price, imageUrl, description, bundleHandle) {
    console.log('🔓 Opening popup for:', title);
    console.log('🎁 Bundle configured:', bundleHandle || 'NONE');
    
    resetVariants();
    currentBundleHandle = bundleHandle;
    
    document.getElementById('popup-product-title').textContent = title;
    document.getElementById('popup-product-price').textContent = formatMoney(parseInt(price));
    document.getElementById('popup-product-description').textContent = description || 'No description available';
    document.getElementById('popup-product-image').src = imageUrl || '';
    
    const popup = document.getElementById('product-popup');
    popup.classList.add('active');
    document.body.style.overflow = 'hidden';
    
    const fullProduct = await fetchProduct(handle);
    if (fullProduct) {
      currentProductData = fullProduct;
      updateVariantOptions(fullProduct);
    }
  };
  
  window.closePopup = function() {
    const popup = document.getElementById('product-popup');
    popup.classList.remove('active');
    document.body.style.overflow = '';
    currentProductData = null;
    currentVariant = null;
    currentBundleHandle = null;
    resetVariants();
    const quantityInput = document.getElementById('quantity-input');
    if (quantityInput) quantityInput.value = 1;
  };
  
  function attachProductCardHandlers() {
    const cards = document.querySelectorAll('.product-card');
    console.log('📦 Found product cards:', cards.length);
    
    cards.forEach(card => {
      const handler = () => {
        const handle = card.dataset.productHandle;
        const title = card.dataset.productTitle;
        const price = card.dataset.productPrice;
        const image = card.dataset.productImage;
        const description = card.dataset.productDescription;
        const bundleHandle = card.dataset.bundleHandle || '';
        
        console.log(`🖱️ Product clicked: ${title}`);
        console.log(`🎁 Bundle handle: ${bundleHandle || 'NONE'}`);
        window.openProductPopup(handle, title, price, image, description, bundleHandle);
      };
      
      card.removeEventListener('click', card._handler);
      card._handler = handler;
      card.addEventListener('click', handler);
      card.style.cursor = 'pointer';
    });
  }
  
  function setupQuantityControls() {
    const decreaseBtn = document.querySelector('[data-action="decrease"]');
    const increaseBtn = document.querySelector('[data-action="increase"]');
    const quantityInput = document.getElementById('quantity-input');
    
    if (decreaseBtn) {
      decreaseBtn.onclick = () => {
        let val = parseInt(quantityInput.value);
        if (val > 1) quantityInput.value = val - 1;
      };
    }
    
    if (increaseBtn) {
      increaseBtn.onclick = () => {
        let val = parseInt(quantityInput.value);
        quantityInput.value = val + 1;
      };
    }
  }
  
  document.addEventListener('DOMContentLoaded', function() {
    console.log('🚀 ========================================');
    console.log('🚀 Product Grid Initialized');
    console.log('🚀 Bundle Trigger: Black + M Only');
    console.log('🚀 Duplicate Prevention: ENABLED');
    console.log('🚀 ========================================');
    
    attachProductCardHandlers();
    setupQuantityControls();
    
    const addToCartBtn = document.getElementById('add-to-cart-btn');
    if (addToCartBtn) addToCartBtn.onclick = handleAddToCart;
    
    const closeBtn = document.querySelector('.popup-close');
    if (closeBtn) closeBtn.onclick = window.closePopup;
    
    const popup = document.getElementById('product-popup');
    if (popup) {
      popup.onclick = (e) => {
        if (e.target === popup) window.closePopup();
      };
    }
    
    const sortBtn = document.getElementById('sortBtn');
    const sortMenu = document.getElementById('sortMenu');
    const productGrid = document.getElementById('productGrid');
    
    if (sortBtn && sortMenu) {
      sortBtn.onclick = (e) => {
        e.stopPropagation();
        sortMenu.classList.toggle('active');
      };
      
      document.querySelectorAll('.sort-menu button').forEach(btn => {
        btn.onclick = () => {
          const sortType = btn.dataset.sort;
          const cards = Array.from(document.querySelectorAll('.product-card'));
          
          cards.sort((a, b) => {
            const titleA = a.dataset.productTitle || '';
            const titleB = b.dataset.productTitle || '';
            const priceA = parseInt(a.dataset.productPrice) || 0;
            const priceB = parseInt(b.dataset.productPrice) || 0;
            
            switch(sortType) {
              case 'title-asc': return titleA.localeCompare(titleB);
              case 'title-desc': return titleB.localeCompare(titleA);
              case 'price-asc': return priceA - priceB;
              case 'price-desc': return priceB - priceA;
              default: return 0;
            }
          });
          
          cards.forEach(card => productGrid.appendChild(card));
          sortMenu.classList.remove('active');
          attachProductCardHandlers();
        };
      });
      
      document.addEventListener('click', () => {
        sortMenu.classList.remove('active');
      });
    }
    
    const viewBtns = document.querySelectorAll('.view-btn');
    viewBtns.forEach(btn => {
      btn.onclick = () => {
        viewBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        if (btn.dataset.view === 'list') {
          productGrid.classList.add('list-view');
        } else {
          productGrid.classList.remove('list-view');
        }
      };
    });
  });
})();
</script>

