{%- liquid
  assign section_title = section.settings.section_title
  assign products_limit = section.settings.products_limit
  assign collection_handle = section.settings.collection
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile

 assign currentBundleHandle = nil
  # Try to find Winter Jacket by different handles
  assign winter_jacket = all_products['soft-winter-jacket']
  if winter_jacket == blank
    assign winter_jacket = all_products['winter-jacket']
  endif
  if winter_jacket == blank
    assign winter_jacket = all_products['winter-coat']
  endif

  if winter_jacket != blank
    assign winter_jacket_variant_id = winter_jacket.variants.first.id
    assign winter_jacket_title = winter_jacket.title
  else
    assign winter_jacket_variant_id = 0
    assign winter_jacket_title = 'Not Found'
  endif
-%}

<div class="product-grid-section" id="product-grid-section">
  <div class="container">
    <div class="section-header">
      <div class="section-header-left">
        <h2 class="section-title">{{ section_title | escape }}</h2>
        <span class="product-count-badge">
          {%- if collection_handle != blank -%}
            {%- assign collection = collections[collection_handle] -%}
            {{ collection.products_count }}
          {%- else -%}
            {{ collections.all.products_count }}
          {%- endif -%}
          items
        </span>
      </div>
      <div class="section-header-right">
        <div class="sort-dropdown">
          <button class="sort-btn" id="sortBtn">
            <span>Sort by</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </button>
          <div class="sort-menu" id="sortMenu">
            <button data-sort="featured">Featured</button>
            <button data-sort="title-asc">Alphabetically, A-Z</button>
            <button data-sort="title-desc">Alphabetically, Z-A</button>
            <button data-sort="price-asc">Price, low to high</button>
            <button data-sort="price-desc">Price, high to low</button>
          </div>
        </div>
        <div class="view-controls">
          <button class="view-btn active" data-view="grid" aria-label="Grid view">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="7"/>
              <rect x="14" y="3" width="7" height="7"/>
              <rect x="3" y="14" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/>
            </svg>
          </button>
          <button class="view-btn" data-view="list" aria-label="List view">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="product-grid" id="productGrid" data-columns="{{ columns_desktop }}">
      {%- assign products_to_show = collections[collection_handle].products | default: collections.all.products -%}

      {%- for product in products_to_show limit: products_limit -%}
        <div
          class="product-card"
          data-product-id="{{ product.id }}"
          data-product-handle="{{ product.handle }}"
          data-product-title="{{ product.title | escape }}"
          data-product-price="{{ product.price }}"
          data-product-image="{{ product.featured_image | image_url: width: 600 }}"
          data-product-description="{{ product.description | strip_html | escape }}"
          data-bundle-handle="{{ product.metafields.custom.bundle_product | default: '' }}"
        >
          <div class="product-card-inner">
            <div class="product-image-wrapper">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="product-image"
                  width="400"
                  height="400"
                  loading="lazy"
                >
                <div class="product-overlay">
                  <button class="quick-view-btn">Quick View</button>
                </div>
              {%- else -%}
                <div class="product-placeholder">
                  <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <circle cx="8.5" cy="8.5" r="2.5"/>
                    <path d="M21 15L16 10L5 21"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>
            <div class="product-info">
              <h3 class="product-title">{{ product.title | escape }}</h3>
              <div class="product-price-wrapper">
                {%- if product.compare_at_price > product.price -%}
                  <span class="current-price sale">{{ product.price | money }}</span>
                  <span class="compare-price">{{ product.compare_at_price | money }}</span>
                {%- else -%}
                  <span class="current-price">{{ product.price | money }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
      {%- else -%}
        <div class="no-products-message">
          <p>No products found. Please add products to your store.</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<!-- Product Quick View Popup -->
<div id="product-popup" class="popup-overlay">
  <div class="popup-container">
    <button class="popup-close" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div class="popup-content">
      <div class="popup-gallery">
        <div class="popup-main-image">
          <img id="popup-product-image" src="" alt="Product image">
        </div>
      </div>
      <div class="popup-details">
        <h2 id="popup-product-title" class="popup-title"></h2>
        <div class="popup-price-wrapper">
          <span id="popup-product-price" class="popup-price"></span>
          <span id="popup-regular-price" class="popup-compare-price"></span>
        </div>
        <div id="popup-product-description" class="popup-description"></div>

        <div class="variant-selectors">
          <div class="variant-group">
            <label class="variant-label">Size</label>
            <div class="variant-options" id="size-options"></div>
          </div>
          <div class="variant-group">
            <label class="variant-label">Color</label>
            <div class="variant-options" id="color-options"></div>
          </div>
        </div>

        <div class="popup-actions">
          <div class="quantity-selector">
            <button class="quantity-btn" data-action="decrease" aria-label="Decrease quantity">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
            <input type="number" id="quantity-input" value="1" min="1" class="quantity-input">
            <button class="quantity-btn" data-action="increase" aria-label="Increase quantity">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
          </div>
          <button id="add-to-cart-btn" class="add-to-cart-btn">
            <span>Add to Cart</span>
          </button>
        </div>

        <div id="cart-message" class="cart-message"></div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  'use strict';
  
  // ============================================
  // BUNDLE PRODUCT CONFIGURATION
  // ============================================
  // OPTION 1: Auto-detected from Shopify (if product exists)
  const AUTO_BUNDLE_VARIANT_ID = {{ winter_jacket_variant_id | json }};
  const AUTO_BUNDLE_TITLE = {{ winter_jacket_title | json }};
  
  {% comment %} // OPTION 2: MANUAL CONFIGURATION - CHANGE THIS TO YOUR PRODUCT'S VARIANT ID
  // To get variant ID: Go to Shopify Admin > Products > Click on your product
  // Look at URL: /admin/products/1234567890/variants/9876543210
  // The number after 'variants/' is your variant ID
  const MANUAL_BUNDLE_VARIANT_ID = 0; // 🔴 PUT YOUR VARIANT ID HERE (e.g., 41234567890123)
  
  // OPTION 3: Use any product from your store by handle
  // Change 'your-product-handle' to the actual handle of the product you want to add
  const BUNDLE_PRODUCT_HANDLE = 'black-leather-bag'; // 🔴 CHANGE THIS to your product handle {% endcomment %}
  
  // Determine which variant ID to use
  let BUNDLE_VARIANT_ID = AUTO_BUNDLE_VARIANT_ID;
  let BUNDLE_PRODUCT_NAME = AUTO_BUNDLE_TITLE;
  
  if (MANUAL_BUNDLE_VARIANT_ID !== 0) {
    BUNDLE_VARIANT_ID = MANUAL_BUNDLE_VARIANT_ID;
    BUNDLE_PRODUCT_NAME = 'Bundle Product';
    console.log('📦 Using MANUAL bundle variant ID:', BUNDLE_VARIANT_ID);
  } else if (AUTO_BUNDLE_VARIANT_ID !== 0) {
    console.log('📦 Using AUTO-DETECTED bundle product:', BUNDLE_PRODUCT_NAME, 'ID:', BUNDLE_VARIANT_ID);
  } else {
    console.log('📦 Will fetch bundle product by handle:', BUNDLE_PRODUCT_HANDLE);
  }
  
  // ============================================
  // DOM Elements
  // ============================================
  const popup = document.getElementById('product-popup');
  const closeBtn = document.querySelector('.popup-close');
  const addToCartBtn = document.getElementById('add-to-cart-btn');
  const quantityInput = document.getElementById('quantity-input');
  
  // ============================================
  // State Variables
  // ============================================
  let currentProduct = null;
  let currentVariant = null;
  let selectedSize = null;
  let selectedColor = null;
  let isAddingToCart = false;
  let bundleVariantId = null;
  let bundleProductName = null;
  
  // ============================================
  // Helper Functions
  // ============================================
  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }
  
  function showMessage(message, isError = false) {
    const messageDiv = document.getElementById('cart-message');
    if (messageDiv) {
      messageDiv.textContent = message;
      messageDiv.className = `cart-message ${isError ? 'error' : 'success'}`;
      setTimeout(() => {
        messageDiv.classList.remove('success', 'error');
        messageDiv.textContent = '';
      }, 3000);
    }
  }
  
  // ============================================
  // FETCH BUNDLE PRODUCT BY HANDLE
  // ============================================
  async function fetchBundleProductByHandle(handle) {
    try {
      console.log('🔍 Fetching bundle product by handle:', handle);
      const response = await fetch(`/products/${handle}.js`);
      if (!response.ok) throw new Error(`Product "${handle}" not found`);
      const product = await response.json();
      console.log('✅ Bundle product found:', product.title);
      return product;
    } catch (error) {
      console.error('❌ Failed to fetch bundle product:', error);
      return null;
    }
  }
  
  // ============================================
  // GET BUNDLE VARIANT ID (Priority order)
  // ============================================
  async function getBundleVariantId() {
  // If product has bundle handle
  if (currentBundleHandle) {
    const bundleProduct = await fetchBundleProductByHandle(currentBundleHandle);

    if (bundleProduct && bundleProduct.variants.length > 0) {
      bundleVariantId = bundleProduct.variants[0].id;
      bundleProductName = bundleProduct.title;
      console.log('✅ Dynamic bundle loaded:', bundleProductName);
      return true;
    }
  }

  console.warn('⚠️ No bundle assigned for this product');
  return false;
}
    
    console.error('❌ No bundle product configured!');
    console.log('💡 To fix this:');
    console.log('   1. Set MANUAL_BUNDLE_VARIANT_ID to your product\'s variant ID');
    console.log('   2. OR set BUNDLE_PRODUCT_HANDLE to an existing product handle');
    console.log('   3. OR create a product with handle "soft-winter-jacket"');
    return false;
  }
  
  // ============================================
  // ADD TO CART FUNCTION
  // ============================================
  async function addToCart(variantId, quantity, productName = 'Product') {
    console.log(`🛒 Adding to cart: ${productName} (Variant: ${variantId}, Qty: ${quantity})`);
    
    try {
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ 
          id: parseInt(variantId), 
          quantity: parseInt(quantity) 
        })
      });
      
      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.description || 'Failed to add to cart');
      }
      
      const data = await response.json();
      console.log(`✅ Successfully added: ${productName}`, data);
      return data;
    } catch (error) {
      console.error(`❌ Failed to add ${productName}:`, error);
      throw error;
    }
  }
  
  // ============================================
  // UPDATE CART COUNT
  // ============================================
  async function updateCartCount() {
    try {
      const response = await fetch('/cart.js');
      const cart = await response.json();
      const cartCountElements = document.querySelectorAll('.cart-count, .cart-item-count, .site-header__cart-count, .header__icon--cart .count');
      cartCountElements.forEach(el => {
        if (el) el.textContent = cart.item_count;
      });
      console.log('🛒 Cart updated, total items:', cart.item_count);
      return cart.item_count;
    } catch (error) {
      console.error('Error updating cart count:', error);
      return 0;
    }
  }
  
  // ============================================
  // BUNDLE LOGIC (Black + Medium = Bundle Product)
  // ============================================
  async function handleSpecialBundle() {
    console.log('🔍 Checking bundle condition...');
    console.log(`   Selected Color: ${selectedColor}`);
    console.log(`   Selected Size: ${selectedSize}`);
    const conditionMet = (selectedColor === 'Black' && selectedSize === 'M');
    console.log(`   Condition met: ${conditionMet}`);
    
    if (conditionMet) {
      console.log('🎯 CONDITION MATCHED! Adding bundle product to cart...');
      
      if (!bundleVariantId) {
        console.error('❌ Bundle variant ID not available!');
        showMessage('⚠️ Bundle product not configured. Please contact support.', true);
        return false;
      }
      
      try {
        const result = await addToCart(bundleVariantId, 1, bundleProductName || 'Bundle Product');
        console.log('✅ Bundle product successfully added to cart!', result);
        showMessage(`🎁 Special offer: ${bundleProductName || 'Bundle product'} added to your cart!`);
        return true;
      } catch (error) {
        console.error('❌ Failed to add bundle product:', error);
        showMessage('Bundle product could not be added.', true);
        return false;
      }
    } else {
      console.log('ℹ️ Bundle condition not met - skipping');
      return false;
    }
  }
  
  // ============================================
  // MAIN ADD TO CART HANDLER
  // ============================================
  async function handleAddToCart() {
    if (isAddingToCart) {
      console.log('⏳ Already processing, please wait...');
      return;
    }
    
    if (!currentProduct) {
      showMessage('Loading product details...', true);
      return;
    }
    
    const quantity = parseInt(quantityInput?.value) || 1;
    const variantToAdd = currentVariant || currentProduct.variants[0];
    
    if (!variantToAdd) {
      showMessage('Please select size and color', true);
      return;
    }
    
    console.log('📦 Processing main product:', {
      productName: currentProduct.title,
      variantId: variantToAdd.id,
      size: selectedSize,
      color: selectedColor,
      quantity: quantity
    });
    
    isAddingToCart = true;
    const btn = addToCartBtn;
    const originalText = btn?.innerHTML;
    
    if (btn) {
      btn.innerHTML = '<span>⏳ Adding...</span>';
      btn.disabled = true;
    }
    
    try {
      // Step 1: Add main product
      await addToCart(variantToAdd.id, quantity, currentProduct.title);
      console.log('✅ Main product added successfully');
      
      // Step 2: Check and add bundle product
      const bundleAdded = await handleSpecialBundle();
      
      // Step 3: Update cart count
      const totalItems = await updateCartCount();
      
      // Show final message
      if (bundleAdded) {
        showMessage(`✓ ${currentProduct.title} + ${bundleProductName} added to cart! 🎁`);
      } else {
        showMessage(`✓ ${currentProduct.title} added to cart successfully!`);
      }
      
      // Close popup after delay
      setTimeout(() => {
        closePopup();
      }, 2000);
      
    } catch (error) {
      console.error('❌ Error in add to cart process:', error);
      showMessage('Failed to add to cart. Please try again.', true);
    } finally {
      if (btn) {
        btn.innerHTML = originalText || '<span>Add to Cart</span>';
        btn.disabled = false;
      }
      isAddingToCart = false;
    }
  }
  
  // ============================================
  // FETCH PRODUCT DATA
  // ============================================
  async function fetchProduct(handle) {
    try {
      const response = await fetch(`/products/${handle}.js`);
      if (!response.ok) throw new Error('Product not found');
      const product = await response.json();
      console.log(`📦 Product loaded: ${product.title}`, product);
      return product;
    } catch (error) {
      console.error('Error fetching product:', error);
      return null;
    }
  }
  
  // ============================================
  // UPDATE VARIANT OPTIONS
  // ============================================
  function updateVariantOptions(product) {
    const sizes = new Set();
    const colors = new Set();
    
    product.variants.forEach(variant => {
      variant.options.forEach(option => {
        if (['XS', 'S', 'M', 'L', 'XL', 'XXL', 'Small', 'Medium', 'Large'].includes(option)) {
          sizes.add(option);
        } else if (['Black', 'White', 'Red', 'Blue', 'Green', 'Yellow', 'Pink', 'Brown', 'Purple', 'Orange'].includes(option)) {
          colors.add(option);
        }
      });
    });
    
    // Size options
    const sizeContainer = document.getElementById('size-options');
    if (sizeContainer) {
      sizeContainer.innerHTML = '';
      if (sizes.size === 0) {
        ['S', 'M', 'L'].forEach(size => sizes.add(size));
      }
      
      sizes.forEach(size => {
        const option = document.createElement('button');
        option.className = 'variant-option';
        if (selectedSize === size) option.classList.add('selected');
        option.textContent = size;
        option.onclick = (e) => {
          e.preventDefault();
          document.querySelectorAll('#size-options .variant-option').forEach(opt => {
            opt.classList.remove('selected');
          });
          option.classList.add('selected');
          selectedSize = size;
          console.log('📏 Size selected:', size);
          updateSelectedVariant(product);
        };
        sizeContainer.appendChild(option);
      });
    }
    
    // Color options
    const colorContainer = document.getElementById('color-options');
    if (colorContainer) {
      colorContainer.innerHTML = '';
      if (colors.size === 0) {
        ['Black', 'White'].forEach(color => colors.add(color));
      }
      
      colors.forEach(color => {
        const option = document.createElement('button');
        option.className = 'variant-option';
        if (selectedColor === color) option.classList.add('selected');
        option.textContent = color;
        option.onclick = (e) => {
          e.preventDefault();
          document.querySelectorAll('#color-options .variant-option').forEach(opt => {
            opt.classList.remove('selected');
          });
          option.classList.add('selected');
          selectedColor = color;
          console.log('🎨 Color selected:', color);
          updateSelectedVariant(product);
        };
        colorContainer.appendChild(option);
      });
    }
  }
  
  function updateSelectedVariant(product) {
    if (selectedSize && selectedColor) {
      currentVariant = product.variants.find(variant => {
        return return variant.option1 === selectedSize && variant.option2 === selectedColor;
      });
      if (currentVariant) {
        const priceElement = document.getElementById('popup-product-price');
        if (priceElement) {
          priceElement.textContent = formatMoney(currentVariant.price);
        }
        console.log('🔄 Variant updated:', {
          size: selectedSize,
          color: selectedColor,
          variantId: currentVariant.id,
          price: formatMoney(currentVariant.price)
        });
      }
    }
  }
  
  // ============================================
  // OPEN POPUP
  // ============================================
  async function openProductPopup(handle, title, price, imageUrl, description) {
    console.log('🔓 Opening popup for:', handle);
    
    document.getElementById('popup-product-title').textContent = title;
    document.getElementById('popup-product-price').textContent = formatMoney(parseInt(price));
    document.getElementById('popup-product-description').textContent = description || 'No description available';
    document.getElementById('popup-product-image').src = imageUrl || '';
    
    selectedSize = null;
    selectedColor = null;
    currentVariant = null;
    
    popup.classList.add('active');
    document.body.style.overflow = 'hidden';
    
    const fullProduct = await fetchProduct(handle);
    await getBundleVariantId();
    if (fullProduct) {
      currentProduct = fullProduct;
      updateVariantOptions(fullProduct);
    }
  }
  
  function closePopup() {
    console.log('🔒 Closing popup');
    popup.classList.remove('active');
    document.body.style.overflow = '';
    currentProduct = null;
    currentVariant = null;
    selectedSize = null;
    selectedColor = null;
    
    document.querySelectorAll('.variant-option').forEach(opt => {
      opt.classList.remove('selected');
    });
    
    if (quantityInput) quantityInput.value = 1;
  }
  
  // ============================================
  // QUANTITY CONTROLS
  // ============================================
  function setupQuantityControls() {
    const decreaseBtn = document.querySelector('[data-action="decrease"]');
    const increaseBtn = document.querySelector('[data-action="increase"]');
    
    if (decreaseBtn) {
      decreaseBtn.onclick = () => {
        let val = parseInt(quantityInput.value);
        if (val > 1) quantityInput.value = val - 1;
      };
    }
    
    if (increaseBtn) {
      increaseBtn.onclick = () => {
        let val = parseInt(quantityInput.value);
        quantityInput.value = val + 1;
      };
    }
  }
  
  // ============================================
  // PRODUCT CARD HANDLERS
  // ============================================
  function attachProductCardHandlers() {
    const cards = document.querySelectorAll('.product-card');
    console.log('📦 Found product cards:', cards.length);
    
    cards.forEach(card => {
      if (card._clickHandler) {
        card.removeEventListener('click', card._clickHandler);
      }
      
      const handler = (e) => {
        if (e.target.classList && e.target.classList.contains('quick-view-btn')) {
          e.stopPropagation();
        }
        
        const handle = card.dataset.productHandle;
        currentBundleHandle = card.dataset.bundleHandle || null;
console.log('📦 Bundle handle:', currentBundleHandle);
        const title = card.dataset.productTitle;
        const price = card.dataset.productPrice;
        const image = card.dataset.productImage;
        const description = card.dataset.productDescription;
        
        console.log('🖱️ Product card clicked:', handle);
        openProductPopup(handle, title, price, image, description);
      };
      
      card._clickHandler = handler;
      card.addEventListener('click', handler);
    });
  }
  
  // ============================================
  // SORTING
  // ============================================
  function setupSorting() {
    const sortBtn = document.getElementById('sortBtn');
    const sortMenu = document.getElementById('sortMenu');
    const productGrid = document.getElementById('productGrid');
    
    if (sortBtn && sortMenu) {
      sortBtn.onclick = (e) => {
        e.stopPropagation();
        sortMenu.classList.toggle('active');
      };
      
      document.querySelectorAll('.sort-menu button').forEach(btn => {
        btn.onclick = () => {
          const sortType = btn.dataset.sort;
          const cards = Array.from(document.querySelectorAll('.product-card'));
          
          cards.sort((a, b) => {
            const titleA = a.dataset.productTitle || '';
            const titleB = b.dataset.productTitle || '';
            const priceA = parseInt(a.dataset.productPrice) || 0;
            const priceB = parseInt(b.dataset.productPrice) || 0;
            
            switch(sortType) {
              case 'title-asc': return titleA.localeCompare(titleB);
              case 'title-desc': return titleB.localeCompare(titleA);
              case 'price-asc': return priceA - priceB;
              case 'price-desc': return priceB - priceA;
              default: return 0;
            }
          });
          
          cards.forEach(card => productGrid.appendChild(card));
          sortMenu.classList.remove('active');
          attachProductCardHandlers();
        };
      });
      
      document.addEventListener('click', (e) => {
        if (!sortBtn.contains(e.target) && !sortMenu.contains(e.target)) {
          sortMenu.classList.remove('active');
        }
      });
    }
  }
  
  // ============================================
  // VIEW TOGGLE
  // ============================================
  function setupViewToggle() {
    const viewBtns = document.querySelectorAll('.view-btn');
    const productGrid = document.getElementById('productGrid');
    
    viewBtns.forEach(btn => {
      btn.onclick = () => {
        viewBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        if (btn.dataset.view === 'list') {
          productGrid.classList.add('list-view');
        } else {
          productGrid.classList.remove('list-view');
        }
      };
    });
  }
  
  // ============================================
  // INITIALIZE
  // ============================================
  async function init() {
    console.log('🚀 ========================================');
    console.log('🚀 Initializing Product Grid with Bundle Support');
    console.log('🚀 ========================================');
    console.log('🎯 Bundle Condition: Color = Black AND Size = M');
    
    // Initialize bundle product
    await getBundleVariantId();
    
    if (bundleVariantId) {
      console.log('✅ Bundle feature is READY!');
      console.log(`   Bundle Product: ${bundleProductName}`);
      console.log(`   Bundle Variant ID: ${bundleVariantId}`);
      console.log('   When user selects: Black + Medium → Bundle product added automatically');
    } else {
      console.warn('⚠️⚠️⚠️ BUNDLE NOT CONFIGURED ⚠️⚠️⚠️');
      console.warn('To fix, do ONE of the following:');
      console.warn('   1. Set MANUAL_BUNDLE_VARIANT_ID to your product\'s variant ID');
      console.warn('   2. Set BUNDLE_PRODUCT_HANDLE to an existing product handle (e.g., "black-leather-bag")');
      console.warn('   3. Create a product with handle "soft-winter-jacket"');
    }
    console.log('🚀 ========================================');
    
    attachProductCardHandlers();
    setupSorting();
    setupViewToggle();
    setupQuantityControls();
    
    if (closeBtn) closeBtn.onclick = closePopup;
    if (addToCartBtn) addToCartBtn.onclick = handleAddToCart;
    if (popup) popup.onclick = (e) => { if (e.target === popup) closePopup(); };
  }
  
  // Run when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

