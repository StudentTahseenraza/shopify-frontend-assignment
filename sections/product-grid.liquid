{%- liquid
  assign section_title = section.settings.section_title
  assign products_limit = section.settings.products_limit
  assign collection_handle = section.settings.collection
  assign columns_desktop = section.settings.columns_desktop
-%}

<div class="product-grid-section" id="product-grid-section">
  <div class="container">
    <div class="section-header">
      <div class="section-header-left">
        <h2 class="section-title">{{ section_title | escape }}</h2>
        <span class="product-count-badge">
          {%- if collection_handle != blank -%}
            {%- assign collection = collections[collection_handle] -%}
            {{ collection.products_count }}
          {%- else -%}
            {{ collections["all"].products_count }}
          {%- endif -%}
          items
        </span>
      </div>
      <div class="section-header-right">
        <div class="sort-dropdown">
          <button class="sort-btn" id="sortBtn">
            <span>Sort by</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </button>
          <div class="sort-menu" id="sortMenu">
            <button data-sort="featured">Featured</button>
            <button data-sort="title-asc">Alphabetically, A-Z</button>
            <button data-sort="title-desc">Alphabetically, Z-A</button>
            <button data-sort="price-asc">Price, low to high</button>
            <button data-sort="price-desc">Price, high to low</button>
          </div>
        </div>
        <div class="view-controls">
          <button class="view-btn active" data-view="grid" aria-label="Grid view">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="7"/>
              <rect x="14" y="3" width="7" height="7"/>
              <rect x="3" y="14" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/>
            </svg>
          </button>
          <button class="view-btn" data-view="list" aria-label="List view">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
    
    <div class="product-grid" id="productGrid">
      {%- assign products_to_show = collections[collection_handle].products | default: collections["all"].products -%}
      
      {%- for product in products_to_show limit: products_limit -%}
        {%- comment %}
          ============================================
          YOUR 20 PRODUCTS WITH CUSTOM BUNDLE MAPPING
          Each product gets its OWN bundle product
          ============================================
        {% endcomment %}
        
        {%- assign bundle_handle = '' -%}
        
        {%- comment %} 
          LIST OF YOUR PRODUCTS FROM IMAGES:
          1. Black Leather Bag
          2. Blue Silk Tuxedo
          3. Chequered Red Shirt
          4. Classic Leather Jacket
          5. Classic Varsity Top
          6. Dark Denim Top
          7. Floral White Top
          8. LED High Tops
          9. Long Sleeve Cotton Top
          10. Navy Sports Jacket
          11. Ocean Blue Shirt
          12. Olive Green Jacket
          13. Red Sports Tee
          14. Silk Summer Top
          15. Soft Winter Jacket
          16. Striped Silk Blouse
          17. Striped Skirt and Top
          18. White Cotton Shirt
          19. Yellow Wool Jumper
          20. Zipped Jacket
        {% endcomment %}
        
        {%- if product.handle == 'blue-silk-tuxedo' -%}
          {%- assign bundle_handle = 'black-leather-bag' -%}
        {%- elsif product.handle == 'zipped-jacket' -%}
          {%- assign bundle_handle = 'dark-denim-top' -%}
        {%- elsif product.handle == 'floral-white-top' -%}
          {%- assign bundle_handle = 'ocean-blue-shirt' -%}
        {%- elsif product.handle == 'yellow-wool-jumper' -%}
          {%- assign bundle_handle = 'classic-varsity-top' -%}
        {%- elsif product.handle == 'chequered-red-shirt' -%}
          {%- assign bundle_handle = 'red-sports-tee' -%}
        {%- elsif product.handle == 'classic-leather-jacket' -%}
          {%- assign bundle_handle = 'soft-winter-jacket' -%}
        {%- elsif product.handle == 'long-sleeve-cotton-top' -%}
          {%- assign bundle_handle = 'white-cotton-shirt' -%}
        {%- elsif product.handle == 'navy-sports-jacket' -%}
          {%- assign bundle_handle = 'olive-green-jacket' -%}
        {%- elsif product.handle == 'silk-summer-top' -%}
          {%- assign bundle_handle = 'striped-silk-blouse' -%}
        {%- elsif product.handle == 'striped-skirt-and-top' -%}
          {%- assign bundle_handle = 'floral-white-top' -%}
        {%- else -%}
          {%- assign bundle_handle = '' -%}
        {%- endif -%}
        
        <div class="product-card" 
             data-product-id="{{ product.id }}"
             data-product-handle="{{ product.handle }}"
             data-product-title="{{ product.title | escape }}"
             data-product-price="{{ product.price }}"
             data-product-image="{{ product.featured_image | image_url: width: 600 }}"
             data-product-description="{{ product.description | strip_html | escape }}"
             data-bundle-handle="{{ bundle_handle }}">
          <div class="product-card-inner">
            <div class="product-image-wrapper">
              {%- if product.featured_image != blank -%}
                <img 
                  src="{{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' }}"
                  alt="{{ product.title | escape }}"
                  class="product-image"
                  width="400"
                  height="400"
                  loading="lazy"
                >
                <div class="product-overlay">
                  <button class="quick-view-btn">Quick View</button>
                </div>
              {%- else -%}
                <div class="product-placeholder">
                  <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#ccc">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <circle cx="8.5" cy="8.5" r="2.5"/>
                    <path d="M21 15L16 10L5 21"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>
            <div class="product-info">
              <h3 class="product-title">{{ product.title | escape }}</h3>
              <div class="product-price-wrapper">
                {%- if product.compare_at_price > product.price -%}
                  <span class="current-price sale">{{ product.price | money }}</span>
                  <span class="compare-price">{{ product.compare_at_price | money }}</span>
                {%- else -%}
                  <span class="current-price">{{ product.price | money }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
      {%- else -%}
        <div class="no-products-message">
          <p>No products found. Please add products to your store.</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<!-- Product Quick View Popup -->
<div id="product-popup" class="popup-overlay">
  <div class="popup-container">
    <button class="popup-close" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    
    <div class="popup-content">
      <div class="popup-image">
        <img id="popup-product-image" src="" alt="Product image">
      </div>
      
      <div class="popup-details">
        <h2 id="popup-product-title" class="popup-title"></h2>
        <div class="popup-price-wrapper">
          <span id="popup-product-price" class="popup-price"></span>
          <span id="popup-regular-price" class="popup-regular-price"></span>
        </div>
        
        <div id="popup-product-description" class="popup-description"></div>
        
        <div class="variant-group">
          <label class="variant-label">Size</label>
          <div class="variant-options" id="size-options"></div>
        </div>
        
        <div class="variant-group">
          <label class="variant-label">Color</label>
          <div class="variant-options" id="color-options"></div>
        </div>
        
        <div class="popup-actions">
          <div class="quantity-selector">
            <button class="quantity-btn" data-action="decrease">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
            <input type="number" id="quantity-input" value="1" min="1" class="quantity-input">
            <button class="quantity-btn" data-action="increase">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
          </div>
          <button id="add-to-cart-btn" class="add-to-cart-btn">Add to Cart</button>
        </div>
        
        <div id="cart-message" class="cart-message"></div>
      </div>
    </div>
  </div>
</div>

